# Server-only local values. Never expose these through NEXT_PUBLIC_* or EXPO_PUBLIC_*.
DATABASE_URL=postgresql://puckflow_app:puckflow_local@127.0.0.1:5432/puckflow
MIGRATION_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/puckflow
CLERK_PUBLISHABLE_KEY=pk_test_example
CLERK_SECRET_KEY=sk_test_example
CLERK_WEBHOOK_SIGNING_SECRET=whsec_example
SENTRY_DSN=https://examplePublicKey@example.ingest.sentry.io/1
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=local
SENTRY_AUTH_TOKEN=sntrys_example
API_INTERNAL_URL=http://127.0.0.1:3001
PORT=3000
LOG_LEVEL=info

# Public client configuration. These values are safe to bundle.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_example
NEXT_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_example
EXPO_PUBLIC_API_URL=http://127.0.0.1:3001
EXPO_PUBLIC_SENTRY_DSN=
